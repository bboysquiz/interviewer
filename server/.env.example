# Backend HTTP server
HOST=0.0.0.0
PORT=3000

# Frontend origin allowed by CORS in development or if you serve the UI from another domain.
# Example for Amvera: CLIENT_ORIGIN=https://your-project.your-name.amvera.io
CLIENT_ORIGIN=http://localhost:5173

# Local storage.
# On Amvera you can omit these variables and the app will use /data/app.db and /data/uploads automatically.
DATABASE_PATH=server/data/app.db
UPLOADS_DIR=server/uploads

# AI provider order
AI_PRIMARY_PROVIDER=gemini
AI_FALLBACK_PROVIDER=groq

# Gemini
GEMINI_API_KEY=
GEMINI_DOH_URL=
GEMINI_DNS_SERVERS=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_INTERVIEW_QUESTION_MODEL=gemini-3.1-flash-lite-preview
GEMINI_INTERVIEW_EVALUATION_MODEL=gemini-3.1-flash-lite-preview

# Groq fallback
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_INTERVIEW_QUESTION_MODEL=openai/gpt-oss-20b
GROQ_INTERVIEW_EVALUATION_MODEL=openai/gpt-oss-20b

# Legacy OpenAI variables (optional, not used by the default Gemini -> Groq flow)
OPENAI_API_KEY=
OPENAI_IMAGE_ANALYSIS_MODEL=gpt-4.1-mini
OPENAI_INTERVIEW_QUESTION_MODEL=gpt-4.1-mini
OPENAI_INTERVIEW_EVALUATION_MODEL=gpt-4.1-mini

# Max grounded context length passed to interview prompts
OPENAI_INTERVIEW_CONTEXT_MAX_CHARS=12000
